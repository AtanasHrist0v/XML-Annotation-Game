<?xml version="1.0" encoding="utf-8"?>
<Game>

	<Settings>

		<HUD enabled="true" anchor="TopRight"
			 showScore="true"
			 showTime="true" timeFormat="seconds"
			 showAttempts="true"
			 showLevel="true" />

		<Scoring correctPoints="1" incorrectPoints="-1" />

		<Room center="0,0,0" />

		<Board id="mainBoard" prefab="Prefabs/Board"
			   pos="0,1.6,6.5" rot="0,180,0" scale="1,1,1"
			   columns="2" cardSpacingX="0.35" cardSpacingY="0.22" />

	</Settings>

	<Models>

		<Model id="cube" name="Куб" prefab="Prefabs/CubeModel">
			<Transform pos="-4,0.4,-1.5" rot="0,55,0" scale="300,300,300" />
			<Render transparency="0.0" />
			<Annotations>
				<Annotation key="name" type="board" text="Куб" />
				<Annotation key="formula_surface" type="board" text="S = 6*a^2" />
				<Annotation key="formula_volume" type="board" text="V = a^3" />
			</Annotations>
		</Model>

		<Model id="sphere" name="Сфера" prefab="Prefabs/SphereModel">
			<Transform pos="0,0.7,-4" rot="0,0,0" scale="300,300,300" />
			<Render transparency="0.0" />
			<Annotations>
				<Annotation key="name" type="board" text="Сфера" />
				<Annotation key="formula_surface" type="board" text="S = 4*pi*r^2" />
				<Annotation key="formula_volume" type="board" text="V = 4/3*pi*r^3" />
			</Annotations>
		</Model>

		<Model id="sq_pyramid" name="Квадратна пирамида" prefab="Prefabs/SquarePyramidModel">
			<Transform pos="0,0.3,4.2" rot="-90,0,0" scale="300,300,300" />
			<Render transparency="0.0" />
			<Annotations>
				<Annotation key="name" type="board" text="Квадратна пирамида" />
			</Annotations>
		</Model>

		<Model id="tri_pyramid" name="Триъгълна пирамида" prefab="Prefabs/TriangularPyramidModel">
			<Transform pos="-4.3,1.3,2.7" rot="0,25,0" scale="60,60,60" />
			<Render transparency="0.0" />
			<Annotations>
				<Annotation key="name" type="board" text="Триъгълна пирамида" />
			</Annotations>
		</Model>

		<Model id="cylinder" name="Цилиндър" prefab="Prefabs/CylinderModel">
			<Transform pos="4,0.5,2" rot="90,0,0" scale="200,200,200" />
			<Render transparency="0.0" />
			<Annotations>
				<Annotation key="name" type="board" text="Цилиндър" />
				<Annotation key="formula_surface" type="board" text="S = 2*pi*r*h + 2*pi*r^2" />
				<Annotation key="formula_volume" type="board" text="V = pi*r^2*h" />
			</Annotations>
		</Model>

		<Model id="rect_prism" name="Правоъгълна призма" prefab="Prefabs/RectangularPrismModel">
			<Transform pos="-0.61,0.7,2.7" rot="0,0,90" scale="60,60,60" />
			<Render transparency="0.0" />
			<Annotations>
				<Annotation key="name" type="board" text="Правоъгълна призма" />
				<Annotation key="formula_volume" type="board" text="V = a*b*c" />
				<Annotation key="formula_surface" type="board" text="S = 2(ab + ac + bc)" />
			</Annotations>
		</Model>

		<Model id="dodecahedron" name="Дванадесетостен" prefab="Prefabs/DodecahedronModel">
			<Transform pos="-0.31,0.94,-3.17" rot="0,15,0" scale="50,50,50" />
			<Render transparency="0.0" />
			<Annotations>
				<Annotation key="name" type="board" text="Дванадесетостен" />
				<Annotation key="formula_surface" type="board" text="S = (5 * a * apotema * 0.5) * 12" />
			</Annotations>
		</Model>

		<Model id="pent_pyramid" name="Петоъгълна пирамида" prefab="Prefabs/PentagonalPyramidModel">
			<Transform pos="-3,0.7,-3" rot="-90,0,0" scale="300,300,300" />
			<Render transparency="0.0" />
			<Annotations>
				<Annotation key="name" type="board" text="Петоъгълна пирамида" />
				<Annotation key="formula_volume" type="board" text="V = 1/3 * (Sa * h)" />
			</Annotations>
		</Model>

		<Model id="cone" name="Конус" prefab="Prefabs/ConeModel">
			<Transform pos="4,0.6,-2" rot="-90,0,0" scale="50,50,50" />
			<Render transparency="0.0" />
			<Annotations>
				<Annotation key="name" type="board" text="Конус" />
				<Annotation key="formula_surface" type="board" text="S1 = pi*r*(l + r)" />
				<Annotation key="formula_volume" type="board" text="V = 1/3*pi*r^2*h" />
			</Annotations>
		</Model>

	</Models>

	<Levels>

		<Level index="1" title="Ниво 1" difficulty="easy">
			<Pair modelId="cube"       annotationKey="name" />
			<Pair modelId="sphere"     annotationKey="name" />
			<Pair modelId="sq_pyramid" annotationKey="name" />
		</Level>

		<Level index="2" title="Ниво 2" difficulty="medium">
			<Pair modelId="tri_pyramid"  annotationKey="name" />
			<Pair modelId="cylinder"     annotationKey="formula_surface" />
			<Pair modelId="rect_prism"   annotationKey="formula_volume" />
			<Pair modelId="dodecahedron" annotationKey="formula_surface" />
		</Level>

		<Level index="3" title="Ниво 3" difficulty="hard">
			<Pair modelId="pent_pyramid" annotationKey="formula_volume" />
			<Pair modelId="rect_prism"   annotationKey="formula_surface" />
			<Pair modelId="sphere"       annotationKey="formula_volume" />
			<Pair modelId="cone"         annotationKey="formula_volume" />
			<Pair modelId="cube"         annotationKey="formula_volume" />
		</Level>

	</Levels>

	<Validation>
		<Rule type="uniquePairs" enabled="true" />
		<Rule type="existingAnnotations" enabled="true" />
	</Validation>

	<Feedback>
		<Sound correct="Audio/Correct.wav" incorrect="Audio/Wrong.wav" />
		<Visual correct="green" incorrect="red" duration="1.5" />
	</Feedback>

</Game>
